# Gradle / Kotlin build caches
.gradle/
.kotlin/
**/build/
/captures
.externalNativeBuild
.cxx

# IDE
*.iml
/.idea/

# macOS
.DS_Store

# Local / machine-specific
local.properties
*.jks
*.keystore

# JS tooling (Playwright streamer deps, etc.)
node_modules/

# Note: kotlin-js-store/yarn.lock IS committed on purpose (it locks JS deps).

# Claude Code local settings (per-user, not shared)
.claude/

# Design handoff: assets/ are regenerated by `designExport`; incoming/ is scratch from Claude Design.
# The committed bundle (PROMPT.md, design-tokens.json, spec.html) is tracked; these derived dirs are not.
#design/assets/
#design/incoming/*
#!design/incoming/.gitkeep
# generated by `designPush` (input to /design-sync)
design/.design-push-manifest.json

# 3D aircraft models: large binaries (50-500 MB each), dev-box-only — never committed.
# Fetch via `./gradlew downloadModels` / `scripts/download-models.sh`. See
# design/aircraft-reference/models/README.md for the Code<->Design handoff plan.
# Allow-list (not an extension list): Sketchfab's manual download offers glTF/GLB, USDZ,
# or the uploader's arbitrary "Original" source format (FBX/OBJ/Blend/Collada/Max/C4D/
# anything) depending on the model, so enumerating extensions would miss formats.
design/aircraft-reference/models/*
!design/aircraft-reference/models/README.md
